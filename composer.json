{
    "name": "scafera/layered",
    "description": "Layered architecture conventions for the Scafera framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["scafera", "architecture", "layered", "php"],
    "homepage": "https://github.com/scafera/layered",
    "support": {
        "issues": "https://github.com/scafera/layered/issues",
        "source": "https://github.com/scafera/layered"
    },
    "require": {
        "php": ">=8.4",
        "scafera/kernel": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Scafera\\Layered\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scafera\\Layered\\Tests\\": "tests/"
        }
    },
    "extra": {
        "scafera-architecture": "Scafera\\Layered\\LayeredArchitecture",
        "scafera-scaffold": {
            "files": {
                "tests/bootstrap.php": "support/scaffold/tests/bootstrap.php",
                "tests/phpunit.xml.dist": "support/scaffold/tests/phpunit.xml.dist"
            },
            "initial-files": {
                ".gitignore": "support/scaffold/.gitignore"
            },
            "target-map": {
                "index.php": "public/index.php"
            }
        }
    }
}
